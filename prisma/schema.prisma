// StockPilot Pro — Prisma Schema
// Multi-tenant inventory & warehouse management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// AUTH MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum Role {
  OWNER
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  hashedPassword String?
  image          String?
  role           Role      @default(VIEWER)
  isActive       Boolean   @default(true)
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]
  aiExtractions AiExtraction[]

  @@index([organizationId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ORGANIZATION (MULTI-TENANT)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  industry  String?
  currency  String   @default("USD")
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  categories     Category[]
  suppliers      Supplier[]
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  aiExtractions  AiExtraction[]

  @@index([slug])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// INVENTORY MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Supplier {
  id          String  @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?
  website     String?
  contactName String?
  notes       String? @db.Text
  isActive    Boolean @default(true)
  rating      Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  sku         String
  description String?       @db.Text
  image       String?
  barcode     String?
  unit        String        @default("pcs")
  costPrice   Decimal       @default(0) @db.Decimal(12, 2)
  sellPrice   Decimal       @default(0) @db.Decimal(12, 2)
  minStock    Int           @default(0)
  maxStock    Int           @default(0)
  status      ProductStatus @default(ACTIVE)
  weight      Decimal?      @db.Decimal(10, 3)
  dimensions  String?
  tags        String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  stockItems         StockItem[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WAREHOUSE MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Warehouse {
  id       String  @id @default(cuid())
  name     String
  code     String
  address  String?
  city     String?
  state    String?
  country  String?
  postalCode String?
  capacity Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  zones WarehouseZone[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model WarehouseZone {
  id       String @id @default(cuid())
  name     String
  code     String
  type     String @default("GENERAL")
  capacity Int    @default(0)
  createdAt DateTime @default(now())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  stockItems StockItem[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model StockItem {
  id       String @id @default(cuid())
  quantity Int    @default(0)
  reserved Int    @default(0)
  batch    String?
  expiryDate DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  zoneId String
  zone   WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  movements StockMovement[]

  @@unique([productId, zoneId, batch])
  @@index([productId])
  @@index([zoneId])
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  RETURN
}

model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reference String?
  notes     String?      @db.Text
  createdAt DateTime     @default(now())

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([type])
  @@index([createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ORDER MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model PurchaseOrder {
  id          String      @id @default(cuid())
  orderNumber String
  status      OrderStatus @default(DRAFT)
  totalAmount Decimal     @default(0) @db.Decimal(12, 2)
  tax         Decimal     @default(0) @db.Decimal(12, 2)
  notes       String?     @db.Text
  orderDate   DateTime    @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  items PurchaseOrderItem[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  received  Int     @default(0)

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SalesOrder {
  id           String      @id @default(cuid())
  orderNumber  String
  status       OrderStatus @default(DRAFT)
  customerName String
  customerEmail String?
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  tax          Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?     @db.Text
  orderDate    DateTime    @default(now())
  shippedDate  DateTime?
  deliveredDate DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  items SalesOrderItem[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([status])
}

model SalesOrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  shipped   Int     @default(0)

  orderId String
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SYSTEM MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([organizationId])
}

model AiExtraction {
  id             String       @id @default(cuid())
  imageUrl       String?
  sourceType     String       // "IMAGE" | "INVOICE" | "BARCODE"
  extractedData  Json
  confidence     Json
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

